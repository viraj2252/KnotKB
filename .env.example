# kb-mcp configuration — copy to .env and edit.
# Only KB_MCP_KEY needs a value to get started; everything else has sane defaults.

# ── Core ────────────────────────────────────────────────────────────────────
# Host folder mounted into the container as /kb (the markdown vault).
# Point at your Obsidian vault's agent-kb/ folder if you have one, e.g.
#   KB_HOST_PATH=/Users/you/Obsidian/MyVault/agent-kb
# Leave empty to use a gitignored local ./kb-data dir (created on first `make up`).
KB_HOST_PATH=
# Host port the MCP server binds to on 127.0.0.1.
KB_MCP_PORT=8077
# Postgres connection from inside the compose network. Keep in sync with POSTGRES_* below.
KB_DB_URL=postgresql://kb:kb@kb-postgres:5432/kb
# Path of the vault inside the container. Set by docker-compose; only needed
# here if you run the server/CLI directly on the host.
KB_REPO_PATH=/kb
POSTGRES_USER=kb
POSTGRES_PASSWORD=kb
POSTGRES_DB=kb

# ── Auth ────────────────────────────────────────────────────────────────────
# Bearer token required on every MCP request (health endpoint excepted).
# Generate one: openssl rand -hex 32
KB_MCP_KEY=

# ── Indexing & search ───────────────────────────────────────────────────────
KB_EMBED_MODEL=BAAI/bge-small-en-v1.5
KB_EMBED_DIM=384
# Also index sources/ files (default: only facts).
KB_INDEX_SOURCES=false
# Write-side dedup: cosine >= merge -> merge into existing; >= skip -> drop as duplicate.
KB_DEDUP_MERGE=0.92
KB_DEDUP_SKIP=0.98
# TTL for agent:<name>:scratch facts (pgvector-only, never written to markdown).
KB_SCRATCH_TTL_SECONDS=86400
# Cross-encoder rerank of the top candidates (adds ~90 MB model download on first boot).
KB_RERANK_ENABLED=true
KB_RERANK_MODEL=BAAI/bge-reranker-base
KB_RERANK_CANDIDATES=30
# Rank boost per inbound [[wikilink]] (0 = off).
KB_BACKLINK_BOOST=0

# ── LLM backend (optional — powers `ask`, entity extract, auto-ingest) ──────
# Any OpenAI-compatible chat endpoint. EMPTY = LLM features cleanly disabled.
#   claude-proxy (hermes stack): http://claude-proxy:8000/v1
#   OpenAI:                      https://api.openai.com/v1
#   Ollama (Mac/Windows Docker): http://host.docker.internal:11434/v1
#   LiteLLM:                     http://<host>:4000/v1
KB_SYNTH_BASE_URL=
# Provider: openai = any OpenAI-wire endpoint above; cursor = Cursor SDK
# (work subscriptions). cursor requires CURSOR_API_KEY and an image built
# with KB_EXTRAS=cursor.
KB_SYNTH_PROVIDER=openai
CURSOR_API_KEY=
# Comma-separated pip extras baked into the kb-mcp image at build time.
# Set to "cursor" for the Cursor provider, then `make up` to rebuild.
KB_EXTRAS=
KB_SYNTH_MODEL=claude-sonnet-4-6
KB_SYNTH_KEY=
# Max facts retrieved as context for `ask`.
KB_SYNTH_MAX_FACTS=8

# ── Entity extraction (Spec B; needs the LLM backend) ───────────────────────
KB_EXTRACT_ENABLED=true
# Model override for extraction (empty = use KB_SYNTH_MODEL).
KB_EXTRACT_MODEL=
# Max un-extracted facts processed per nightly run.
KB_EXTRACT_MAX_FACTS=50
KB_ENTITY_TYPES=person,company,project,topic

# ── Auto-ingest (Spec C; needs the LLM backend) ─────────────────────────────
KB_INGEST_ENABLED=true
# Model override for ingest (empty = use KB_SYNTH_MODEL).
KB_INGEST_MODEL=
# Max opt-in sources distilled per nightly run.
KB_INGEST_MAX_SOURCES=10
# Facts scoring below this confidence (0-100) are held in review/ for `kb review --accept`.
KB_INGEST_CONFIDENCE=85

# ── Nightly consolidation ───────────────────────────────────────────────────
# Facts older than this many days are reported as stale.
KB_STALE_DAYS=180
# Near-duplicate pairs at or above this cosine are auto-merged by `kb consolidate --apply`.
KB_AUTOMERGE=0.97
